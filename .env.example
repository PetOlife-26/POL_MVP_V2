# ─────────────────────────────────────────────────────────────────────────────
# PetOLife — Root .env example
#
# Copy this file to .env and fill in values for your environment.
#
#   For LOCAL testing:
#     cp .env.example .env
#     (defaults are already correct for local)
#
#   For PRODUCTION server:
#     cp .env.example .env
#     Set NGINX_CONF and FRONTEND_URL to the production values below.
# ─────────────────────────────────────────────────────────────────────────────

# --- LOCAL (default) ---------------------------------------------------------
NGINX_CONF=./nginx/nginx-local.conf
FRONTEND_URL=http://localhost

# --- PRODUCTION (uncomment and use on the server) ----------------------------
# NGINX_CONF=./nginx/nginx.conf
# FRONTEND_URL=https://petolife.com
